; City Quest 3D - Godot 4.6
config_version=5

[application]
config/name="مدينة المغامرات 3D"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"
boot_splash/bg_color=Color(0.015, 0.025, 0.05, 1)
boot_splash/show_image=false

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/handheld/orientation=1
window/energy_saving/keep_screen_on=true

[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
textures/default_filters/use_nearest_mipmap_filter=false
environment/defaults/default_clear_color=Color(0.035, 0.07, 0.13, 1)

[physics]
3d/default_gravity=18.0

[audio]
driver/enable_input=false
